# 실제 배포 도메인 (Vercel Production/Preview 환경변수로 설정)
# 예: https://mbti-er.vercel.app 또는 커스텀 도메인
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Google Analytics 4 측정 ID (예: G-XXXXXXXXXX)
# 발급 전에는 비워두면 GA 스크립트가 로드되지 않음
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# 애드센스 게시자 ID (예: ca-pub-XXXXXXXXXXXXXXXX)
# 승인 전에는 비워두면 AdSlot이 지금처럼 "광고 영역" placeholder를 그대로 보여줌
NEXT_PUBLIC_ADSENSE_CLIENT_ID=
